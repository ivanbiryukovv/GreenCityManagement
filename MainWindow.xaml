<Window x:Class="GreenCityManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GreenCity — Управление озеленением"
        Height="620" Width="1050"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Top bar -->
        <DockPanel DockPanel.Dock="Top" Margin="6,4">
            <Button Content="Выйти" DockPanel.Dock="Right" Width="60" Height="24"
                    Margin="0,0,6,0" Click="Logout_Click"/>
            <TextBlock x:Name="UserInfoText" DockPanel.Dock="Right" FontSize="12" Foreground="#555"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="GreenCity — Управление озеленением"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </DockPanel>

        <TabControl x:Name="MainTabs" Margin="4">

            <TabItem Header="Растения" x:Name="TabPlants">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="PlantSearch" Width="160" Height="22"
                                 TextChanged="PlantSearch_Changed" VerticalContentAlignment="Center"/>
                        <Button Content="Добавить"      x:Name="BtnAddPlant"    Width="80"  Height="24" Margin="8,0,2,0" Click="AddPlant_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditPlant"   Width="100" Height="24" Margin="2,0"     Click="EditPlant_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeletePlant" Width="70"  Height="24" Margin="2,0"     Click="DeletePlant_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="PlantsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="PlantsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"           Binding="{Binding ID_plant}"                              Width="50"/>
                            <DataGridTextColumn Header="Название"     Binding="{Binding Name}"                                  Width="180"/>
                            <DataGridTextColumn Header="Тип"          Binding="{Binding PlantType.Name}"                        Width="150"/>
                            <DataGridTextColumn Header="Район"        Binding="{Binding District.Name}"                         Width="130"/>
                            <DataGridTextColumn Header="Дата посадки" Binding="{Binding Planting_date, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Статус"       Binding="{Binding Health_status}"                         Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Паспорта" x:Name="TabPassports">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddPassport"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddPassport_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditPassport"   Width="100" Height="24" Margin="2,0"     Click="EditPassport_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeletePassport" Width="70"  Height="24" Margin="2,0"     Click="DeletePassport_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="PassportsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="PassportsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"               Binding="{Binding ID_passport}"                                   Width="50"/>
                            <DataGridTextColumn Header="Растение"         Binding="{Binding Plant.Name}"                                    Width="180"/>
                            <DataGridTextColumn Header="Высота (м)"       Binding="{Binding Height}"                                        Width="90"/>
                            <DataGridTextColumn Header="Возраст (лет)"    Binding="{Binding Age}"                                           Width="100"/>
                            <DataGridTextColumn Header="Последний осмотр" Binding="{Binding Last_inspection_date, StringFormat=dd.MM.yyyy}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Обслуживание" x:Name="TabMaintenance">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddMaintenance"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddMaintenance_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditMaintenance"   Width="100" Height="24" Margin="2,0"     Click="EditMaintenance_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeleteMaintenance" Width="70"  Height="24" Margin="2,0"     Click="DeleteMaintenance_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="MaintenanceGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="MaintenanceGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding ID_maintenance}"                    Width="50"/>
                            <DataGridTextColumn Header="Растение"   Binding="{Binding Plant.Name}"                        Width="160"/>
                            <DataGridTextColumn Header="Вид работы" Binding="{Binding WorkType.Name}"                     Width="150"/>
                            <DataGridTextColumn Header="Сотрудник"  Binding="{Binding Employee.FullName}"                 Width="190"/>
                            <DataGridTextColumn Header="Дата"       Binding="{Binding Work_date, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Результат"  Binding="{Binding Result}"                            Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Сотрудники" x:Name="TabEmployees">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddEmployee"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddEmployee_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditEmployee"   Width="100" Height="24" Margin="2,0"     Click="EditEmployee_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeleteEmployee" Width="70"  Height="24" Margin="2,0"     Click="DeleteEmployee_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="EmployeesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="EmployeesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"        Binding="{Binding ID_employee}" Width="50"/>
                            <DataGridTextColumn Header="Фамилия"   Binding="{Binding LastName}"    Width="130"/>
                            <DataGridTextColumn Header="Имя"       Binding="{Binding FirstName}"   Width="110"/>
                            <DataGridTextColumn Header="Отчество"  Binding="{Binding Surname}"     Width="130"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}"    Width="140"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"       Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Районы" x:Name="TabDistricts">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddDistrict"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddDistrict_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditDistrict"   Width="100" Height="24" Margin="2,0"     Click="EditDistrict_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeleteDistrict" Width="70"  Height="24" Margin="2,0"     Click="DeleteDistrict_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="DistrictsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="DistrictsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding ID_district}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"        Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="350"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Типы растений" x:Name="TabPlantTypes">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddPlantType"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddPlantType_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditPlantType"   Width="100" Height="24" Margin="2,0"     Click="EditPlantType_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeletePlantType" Width="70"  Height="24" Margin="2,0"     Click="DeletePlantType_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="PlantTypesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="PlantTypesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding ID_plant_type}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"          Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"   Width="350"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Виды работ" x:Name="TabWorkTypes">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddWorkType"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddWorkType_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditWorkType"   Width="100" Height="24" Margin="2,0"     Click="EditWorkType_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeleteWorkType" Width="70"  Height="24" Margin="2,0"     Click="DeleteWorkType_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="WorkTypesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="WorkTypesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding ID_work_type}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"         Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"  Width="350"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Пользователи" x:Name="TabUsers">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Добавить"      x:Name="BtnAddUser"    Width="80"  Height="24" Margin="0,0,2,0" Click="AddUser_Click"/>
                        <Button Content="Редактировать" x:Name="BtnEditUser"   Width="100" Height="24" Margin="2,0"     Click="EditUser_Click"/>
                        <Button Content="Удалить"       x:Name="BtnDeleteUser" Width="70"  Height="24" Margin="2,0"     Click="DeleteUser_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              SelectionChanged="UsersGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"    Binding="{Binding ID_user}"   Width="50"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}"     Width="150"/>
                            <DataGridTextColumn Header="ФИО"   Binding="{Binding FullName}"  Width="220"/>
                            <DataGridTextColumn Header="Роль"  Binding="{Binding Role.Name}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>