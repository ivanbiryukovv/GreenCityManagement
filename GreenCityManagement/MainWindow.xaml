<Window x:Class="GreenCityManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GreenCityManagement"
        mc:Ignorable="d"
        Title="GreenCityManagement" Height="500" Width="900">
    <Grid>
        <TabControl>

            <TabItem Header="Растения">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить растение" Height="30" Margin="5" Click="AddPlant_Click"/>
                    <DataGrid x:Name="PlantsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"            Binding="{Binding ID_plant}"                              Width="50"/>
                            <DataGridTextColumn Header="Название"      Binding="{Binding Name}"                                  Width="150"/>
                            <DataGridTextColumn Header="Статус"        Binding="{Binding Health_status}"                         Width="120"/>
                            <DataGridTextColumn Header="Дата посадки"  Binding="{Binding Planting_date, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Районы">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить район" Height="30" Margin="5" Click="AddDistrict_Click"/>
                    <DataGrid x:Name="DistrictsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding ID_district}" Width="50"/>
                            <DataGridTextColumn Header="Название"   Binding="{Binding Name}"        Width="150"/>
                            <DataGridTextColumn Header="Описание"   Binding="{Binding Description}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Типы растений">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить тип" Height="30" Margin="5" Click="AddPlantType_Click"/>
                    <DataGrid x:Name="PlantTypesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding ID_plant_type}" Width="50"/>
                            <DataGridTextColumn Header="Название"   Binding="{Binding Name}"          Width="150"/>
                            <DataGridTextColumn Header="Описание"   Binding="{Binding Description}"   Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Паспорта растений">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить паспорт" Height="30" Margin="5" Click="AddPassport_Click"/>
                    <DataGrid x:Name="PassportsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"               Binding="{Binding ID_passport}"                                   Width="50"/>
                            <DataGridTextColumn Header="ID растения"      Binding="{Binding ID_plant}"                                       Width="80"/>
                            <DataGridTextColumn Header="Высота (м)"       Binding="{Binding Height}"                                         Width="100"/>
                            <DataGridTextColumn Header="Возраст"          Binding="{Binding Age}"                                            Width="80"/>
                            <DataGridTextColumn Header="Последний осмотр" Binding="{Binding Last_inspection_date, StringFormat=dd.MM.yyyy}"   Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Сотрудники">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить сотрудника" Height="30" Margin="5" Click="AddEmployee_Click"/>
                    <DataGrid x:Name="EmployeesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding ID_employee}" Width="50"/>
                            <DataGridTextColumn Header="Фамилия"    Binding="{Binding LastName}"    Width="120"/>
                            <DataGridTextColumn Header="Имя"        Binding="{Binding FirstName}"   Width="100"/>
                            <DataGridTextColumn Header="Отчество"   Binding="{Binding Surname}"     Width="120"/>
                            <DataGridTextColumn Header="Должность"  Binding="{Binding Position}"    Width="120"/>
                            <DataGridTextColumn Header="Телефон"    Binding="{Binding Phone}"        Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Виды работ">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить вид работ" Height="30" Margin="5" Click="AddWorkType_Click"/>
                    <DataGrid x:Name="WorkTypesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding ID_work_type}" Width="50"/>
                            <DataGridTextColumn Header="Название"   Binding="{Binding Name}"         Width="150"/>
                            <DataGridTextColumn Header="Описание"   Binding="{Binding Description}"  Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Обслуживание">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить запись" Height="30" Margin="5" Click="AddMaintenance_Click"/>
                    <DataGrid x:Name="MaintenanceGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"           Binding="{Binding ID_maintenance}"                    Width="50"/>
                            <DataGridTextColumn Header="ID растения"  Binding="{Binding ID_plant}"                          Width="80"/>
                            <DataGridTextColumn Header="Вид работы"   Binding="{Binding ID_work_type}"                      Width="80"/>
                            <DataGridTextColumn Header="Дата"         Binding="{Binding Work_date, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Результат"    Binding="{Binding Result}"                            Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Растение-Сотрудник">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ Добавить связь" Height="30" Margin="5" Click="AddPlantEmployee_Click"/>
                    <DataGrid x:Name="PlantEmployeeGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"             Binding="{Binding ID_plant_employee}" Width="50"/>
                            <DataGridTextColumn Header="ID растения"    Binding="{Binding ID_plant}"          Width="100"/>
                            <DataGridTextColumn Header="ID сотрудника"  Binding="{Binding ID_employee}"       Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
