<Window x:Class="GreenCityManagement.Dialogs.AddMaintenanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить обслуживание" Height="270" Width="350" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <TextBlock Text="ID растения *"/>
        <TextBox x:Name="PlantIdBox" Margin="0,4,0,10"/>
        <TextBlock Text="ID вида работ *"/>
        <TextBox x:Name="WorkTypeIdBox" Margin="0,4,0,10"/>
        <TextBlock Text="Дата (дд.мм.гггг) *"/>
        <TextBox x:Name="DateBox" Margin="0,4,0,10"/>
        <TextBlock Text="Результат *"/>
        <TextBox x:Name="ResultBox" Margin="0,4,0,15"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="80" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Отмена"   Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
