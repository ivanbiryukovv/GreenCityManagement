<Window x:Class="GreenCityManagement.Dialogs.AddPlantDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить растение" Height="320" Width="350" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <TextBlock Text="Название *"/>
        <TextBox x:Name="NameBox" Margin="0,4,0,10"/>
        <TextBlock Text="Тип растения (ID) *"/>
        <TextBox x:Name="PlantTypeBox" Margin="0,4,0,10"/>
        <TextBlock Text="Район (ID) *"/>
        <TextBox x:Name="DistrictBox" Margin="0,4,0,10"/>
        <TextBlock Text="Дата посадки * (дд.мм.гггг)"/>
        <TextBox x:Name="DateBox" Margin="0,4,0,10"/>
        <TextBlock Text="Статус здоровья *"/>
        <TextBox x:Name="StatusBox" Margin="0,4,0,15"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="80" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Отмена"   Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
