<Window x:Class="GreenCityManagement.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="220" Width="340"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Логин" Margin="0,0,0,2"/>
        <TextBox    Grid.Row="1" x:Name="LoginBox" Margin="0,0,0,8" KeyDown="Input_KeyDown"/>

        <TextBlock Grid.Row="2" Text="Пароль" Margin="0,0,0,2"/>
        <PasswordBox Grid.Row="3" x:Name="PasswordBox" Margin="0,0,0,8" KeyDown="Input_KeyDown"/>

        <TextBlock Grid.Row="4" x:Name="ErrorText" Foreground="Red"
                   Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Button Grid.Row="5" Content="Войти" Width="80" HorizontalAlignment="Left" Click="Login_Click"/>
    </Grid>
</Window>
