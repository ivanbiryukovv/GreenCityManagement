<Window x:Class="GreenCityManagement.Dialogs.PassportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паспорт растения" Height="280" Width="380" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Растение *" Margin="0,0,0,3"/>
            <ComboBox x:Name="PlantCombo" Height="26" DisplayMemberPath="Name" SelectedValuePath="ID_plant" Margin="0,0,0,10"/>
            <TextBlock Text="Высота (м) *" Margin="0,0,0,3"/>
            <TextBox x:Name="HeightBox" Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Возраст (лет) *" Margin="0,0,0,3"/>
            <TextBox x:Name="AgeBox" Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Дата последнего осмотра *" Margin="0,0,0,3"/>
            <DatePicker x:Name="DatePicker" Height="26" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="90" Height="28" Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="Отмена"    Width="90" Height="28" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>