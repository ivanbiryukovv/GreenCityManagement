<Window x:Class="GreenCityManagement.Dialogs.NameDescDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="200" Width="380" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock x:Name="LabelName" Text="Название *" Margin="0,0,0,3"/>
            <TextBox x:Name="NameBox" Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Описание" Margin="0,0,0,3"/>
            <TextBox x:Name="DescBox" Height="26" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="90" Height="28" Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="Отмена"    Width="90" Height="28" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>