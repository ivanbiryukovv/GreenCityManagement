<Window x:Class="GreenCityManagement.Dialogs.EmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудник" Height="300" Width="380" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Фамилия *" Margin="0,0,0,3"/>
            <TextBox x:Name="LastNameBox"  Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Имя *" Margin="0,0,0,3"/>
            <TextBox x:Name="FirstNameBox" Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Отчество *" Margin="0,0,0,3"/>
            <TextBox x:Name="SurnameBox"   Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Должность *" Margin="0,0,0,3"/>
            <TextBox x:Name="PositionBox"  Height="26" Margin="0,0,0,10"/>
            <TextBlock Text="Телефон *" Margin="0,0,0,3"/>
            <TextBox x:Name="PhoneBox"     Height="26" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="90" Height="28" Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="Отмена"    Width="90" Height="28" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>